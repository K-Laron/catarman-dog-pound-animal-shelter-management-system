APP_NAME="Catarman Animal Shelter"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://shelter.example.gov.ph
APP_TIMEZONE=Asia/Manila
APP_KEY=change-this-to-a-random-64-char-hex-key
TRUSTED_PROXIES=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=catarman_shelter
DB_USERNAME=root
DB_PASSWORD=

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@catarmanshelter.gov.ph
MAIL_FROM_NAME="Catarman Animal Shelter"

LOG_LEVEL=info
LOG_PATH=storage/logs

SESSION_NAME=catarman_shelter_session
SESSION_LIFETIME=60

UPLOAD_MAX_SIZE=5242880
UPLOAD_PATH=public/uploads
